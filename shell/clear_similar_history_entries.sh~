function clear_similar_history_entries {
    unprocessed_history_size=$(history | grep -cE "^[[:space:]]+([[:digit:]]+)[[:space:]]+" -);while [[ unprocessed_history_size -gt 0 ]]; do
    if [[ $(history $unprocessed_history_size | head -n 1) =~ ^[[:space:]]+([[:digit:]]+)[[:space:]]+([[:alnum:][:space:][:punct:]]+)$ ]]; then
        entry_number=${BASH_REMATCH[1]};
        pattern=${BASH_REMATCH[2]};
        entry_count_in_history=$(history | grep -cF "$pattern" -);
        if [[ $entry_count_in_history -gt 1 ]]; then
            history -d $entry_number;
         fi;
     fi; 
     echo $(( unprocessed_history_size-- )) > /dev/null;
     done; 
unset pattern entry_count_in_history entry_number unprocessed_history_size IFS
}
